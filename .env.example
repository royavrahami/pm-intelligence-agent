# ─────────────────────────────────────────────────────────────────────────────
# PM Intelligence Agent – Environment Configuration
# Copy this file to .env and fill in your values.
# Only OPENAI_API_KEY is required. All other settings have sensible defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI (REQUIRED) ────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model to use for summarisation and trend analysis
# gpt-4o-mini is recommended for cost efficiency
OPENAI_MODEL=gpt-4o-mini

# Maximum tokens per summarisation call
OPENAI_MAX_TOKENS=600

# ── GitHub (optional) ────────────────────────────────────────────────────────
# A GitHub Personal Access Token raises the API rate limit from 60 to 5000/hr.
# Create one at: https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=

# ── Database ─────────────────────────────────────────────────────────────────
# Default: SQLite (no setup needed). For PostgreSQL use:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/pm_agent
DATABASE_URL=sqlite:///./data/pm_agent.db

# ── Scheduler ────────────────────────────────────────────────────────────────
# How often the agent runs (in hours). Default: 6
SCHEDULE_INTERVAL_HOURS=6

# ── Relevance Threshold ───────────────────────────────────────────────────────
# Minimum score (0–100) for an article to be included in reports.
# Lower = more articles, higher = more focused. Default: 55
MIN_RELEVANCE_SCORE=55

# ── Email Notifications (optional) ───────────────────────────────────────────
# All three must be set to enable email alerts.
# Gmail: use an App Password (not your regular password)
# Get App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
NOTIFY_EMAIL=recipient@example.com

# ── Slack Notifications (optional) ───────────────────────────────────────────
# Create a Slack app and get a Bot Token at: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#pm-intelligence

# ── Output Directories ────────────────────────────────────────────────────────
REPORTS_DIR=./reports
LOG_DIR=./logs
